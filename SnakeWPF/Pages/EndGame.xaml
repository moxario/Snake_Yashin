<Page  x:Class="SnakeWPF.Pages.EndGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnakeWPF.Pages"
        mc:Ignorable="d"
        Height="450" Width="800">
    <Grid>
        <Grid Width="320" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label x:Name="name" Content="Ilya" Margin="45, 18, 45, 0" VerticalAlignment="Top" HorizontalContentAlignment="Center" FontSize="16"/>
            <Label x:Name="glasses" Content="90 glasses" Margin="45, 50, 45, 0" VerticalAlignment="Top" HorizontalContentAlignment="Center"/>
            <Button Click="OpenHome" Content="Main Menu" HorizontalAlignment="Left" Margin="45, 0, 0, 10" VerticalAlignment="Bottom" Width="230" Height="25"/>
            <Label x:Name="Top" Content="999" Margin="45, 76, 45, 0" VerticalAlignment="Top" HorizontalContentAlignment="Center" FontFamily="Forte" Height="84" VerticalContentAlignment="Center" FontSize="48"/>

        </Grid>
    </Grid>
</Page>
