<Page x:Class="SnakeWPF.Pages.Home"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SnakeWPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Home">

    <Grid>
        <Grid Width="320" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Введите IP адрес:" HorizontalAlignment="Left" Margin="42, 37, 0, 0" VerticalAlignment="Top"/>
            <Label Content="Порт:" HorizontalAlignment="Left" Margin="202, 37, 0, 0" VerticalAlignment="Top"/>
            <Label Content="Ваше имя:" HorizontalAlignment="Left" Margin="42, 97, 0, 0" VerticalAlignment="Top"/>
            <TextBox x:Name="ip" HorizontalAlignment="Left" Height="25" Margin="42, 62, 0, 0" TextWrapping="Wrap" Text="192.168.0.111" VerticalAlignment="Top" Width="155" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
            <TextBox  x:Name="port"  HorizontalAlignment="Left" Height="25" Margin="202, 62, 0, 0" TextWrapping="Wrap" Text="5000" VerticalAlignment="Top" Width="74" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="name" HorizontalAlignment="Center" Height="25" Margin="0,118,0,0" TextWrapping="Wrap" Text="Ilya" VerticalAlignment="Top" Width="234" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
            <Button Click="StartGame" Content="Game" HorizontalAlignment="Left" Margin="42, 148, 0, 0" VerticalAlignment="Top" Width="234" Height="25"/>
        </Grid>
    </Grid>
</Page>
